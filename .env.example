ENVIRONMENT=local
USER_DB_PASSWORD=user_password
TRAVEL_DB_PASSWORD=travel_password
JWT_SECRET_KEY=replace-with-a-long-random-secret-before-production
# CORS_ORIGINS: allow browser origin and the nginx proxy origin
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# VITE_API_BASE_URL: points to the nginx reverse proxy (replaces FastAPI api-gateway)
# In AWS production, replace with your ALB DNS or CloudFront domain e.g. https://api.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:8080/api
GROQ_API_KEY=
OPENWEATHER_API_KEY=
GEOAPIFY_API_KEY=
GOOGLE_MAPS_API_KEY=
