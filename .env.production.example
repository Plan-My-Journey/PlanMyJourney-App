# Production values are documented here for AWS setup only.
# Do not commit real secrets. Store secret values in AWS Secrets Manager.

ENVIRONMENT=production

# Public URLs
FRONTEND_ORIGIN=https://app.example.com
API_BASE_URL=https://api.example.com/api
CORS_ORIGINS=https://app.example.com

# RDS connection strings. Use the real RDS endpoint and production users.
USER_DATABASE_URL=postgresql+psycopg://user_service:<user-db-password>@<rds-endpoint>:5432/user_db
TRAVEL_DATABASE_URL=postgresql+psycopg://travel_service:<travel-db-password>@<rds-endpoint>:5432/travel_db

# Shared JWT secret. Use one long random value across user/travel/ai/utility services.
JWT_SECRET_KEY=<store-in-aws-secrets-manager>

# External API keys (stored in AWS Secrets Manager)
OPENWEATHER_API_KEY=<store-in-aws-secrets-manager-openweather-api-key>
GEOAPIFY_API_KEY=<store-in-aws-secrets-manager-third-party-apis>

# ECS internal service discovery URLs.
USER_SERVICE_URL=http://user-service.ai-travel.local:8000
TRAVEL_SERVICE_URL=http://travel-service.ai-travel.local:8000
AI_SERVICE_URL=http://ai-service.ai-travel.local:8000
UTILITY_SERVICE_URL=http://utility-service.ai-travel.local:8000
